# Mode SANDBOX pour les tests
NODE_ENV=sandbox
FEDAPAY_SECRET_KEY=sk_sandbox_your_sandbox_key_here
FEDAPAY_SANDBOX_KEY=sk_sandbox_your_sandbox_key_here
FEDAPAY_BASE_URL=https://sandbox-api.fedapay.com/v1
SIMULATION_MODE=false

# Shopify (remplacer par vos cles)
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_APP_URL=http://localhost:3000
SHOPIFY_SCOPES=write_orders,read_products,write_payment_gateways,read_customers,write_checkouts

PORT=3000
