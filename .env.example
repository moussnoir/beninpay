# FedaPay Configuration
FEDAPAY_SECRET_KEY=sk_live_xxx
FEDAPAY_SANDBOX_KEY=sk_sandbox_xxx
FEDAPAY_BASE_URL=https://api.fedapay.com/v1

# Shopify Configuration
SHOPIFY_API_KEY=your_api_key
SHOPIFY_API_SECRET=your_api_secret
SHOPIFY_APP_URL=https://your-app.onrender.com
SHOPIFY_SCOPES=read_orders,write_orders,read_products,read_customers,write_checkouts

# Environment
NODE_ENV=production
PORT=3000

# Database (Render PostgreSQL)
DATABASE_URL=postgresql://user:pass@host:5432/beninpay

# Redis (for Bull queues)
REDIS_URL=redis://127.0.0.1:6379

# Email notifications (Gmail or SendGrid)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Admin
ADMIN_PASSWORD=change_this_in_production

# Sentry error tracking
SENTRY_DSN=https://xxx@sentry.io/xxx

# Mode simulation (true = pas d'appels FedaPay reels)
SIMULATION_MODE=false
