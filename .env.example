# ============================================
# BENINPAY - Configuration complete
# Copier ce fichier en .env et remplir les valeurs
# ============================================

# ===== FedaPay (Paiement Mobile Money) =====
# Cle secrete FedaPay (sk_live_xxx pour production, sk_sandbox_xxx pour test)
# Obtenir sur: https://app.fedapay.com > Parametres > Cles API
FEDAPAY_SECRET_KEY=sk_live_VOTRE_CLE_ICI
FEDAPAY_SANDBOX_KEY=sk_sandbox_VOTRE_CLE_TEST
# URL API (ne pas changer sauf si sandbox: https://sandbox-api.fedapay.com/v1)
FEDAPAY_BASE_URL=https://api.fedapay.com/v1

# ===== Shopify App =====
# Obtenir sur: https://partners.shopify.com > Apps > votre app > API credentials
SHOPIFY_API_KEY=votre_api_key
SHOPIFY_API_SECRET=votre_api_secret
# URL publique de l'app deployee (Render, Railway, etc.)
SHOPIFY_APP_URL=https://beninpay.onrender.com
# Scopes necessaires - NE PAS MODIFIER
SHOPIFY_SCOPES=read_orders,write_orders,read_products,read_customers,write_checkouts,write_script_tags,read_script_tags,read_themes,write_themes

# ===== Base de donnees (OBLIGATOIRE en production) =====
# PostgreSQL via Neon.tech (gratuit 0.5GB)
# 1. Creer compte sur https://neon.tech
# 2. Creer un projet "beninpay"
# 3. Copier le connection string ici
# SANS CA LES DONNEES SONT PERDUES A CHAQUE REDEPLOY!
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# ===== Serveur =====
NODE_ENV=production
PORT=3000

# ===== BeninPay Business =====
# Commission BeninPay sur chaque transaction (en %)
BENINPAY_FEE_PERCENT=3.5
# Mot de passe admin dashboard (/admin-dashboard.html)
ADMIN_PASSWORD=votre_mot_de_passe_securise

# ===== Mode test =====
# true = simule les paiements sans appeler FedaPay (pour dev/test uniquement)
SIMULATION_MODE=false

# ===== Optionnel: Email notifications =====
# Pour notifier les marchands quand un paiement est recu
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=votre-email@gmail.com
# SMTP_PASS=votre-app-password-16-caracteres

# ===== Optionnel: Redis (queues de traitement async) =====
# REDIS_URL=redis://127.0.0.1:6379

# ===== Optionnel: Sentry (monitoring erreurs en production) =====
# SENTRY_DSN=https://xxx@sentry.io/xxx

# ============================================
# PARAMETRES ACTUELS - voir fichier .env local
# (ne JAMAIS commiter les vrais secrets sur GitHub)
# ============================================
# Store: beninpay-test.myshopify.com (dev store)
# Theme live: Horizon #146729238605
# App URL: https://beninpay.onrender.com
